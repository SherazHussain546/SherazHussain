rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-05-V50-ULTRA-STABLE
    // This revision uses explicit operation matching to ensure 'list' operations are authorized.
    
    function isSignedIn() {
      return request.auth != null;
    }

    // projectGoals: Publicly readable, Auth required for all writes
    match /projectGoals/{goalId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // posts: Publicly readable, Auth required for all writes
    match /posts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // siteConfig: Publicly readable, Auth required for writes
    match /siteConfig/{configId} {
      allow get, list: if true;
      allow create, update, delete: if isSignedIn();
    }

    // analyticsEvents: Publicly creatable, Auth read access
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow get, list: if isSignedIn();
    }

    // workflows: Admin-only access
    match /workflows/{workflowId} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}