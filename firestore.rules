
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-05-25-v2
    // REASON: Resolving persistent 'list' operation denials on public collections.
    // Explicitly defining read/write for clarity.

    // Posts: Publicly readable, admin manageable
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Project Goals: Publicly readable, admin manageable
    match /projectGoals/{goalId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Site Config: Publicly readable, admin manageable
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics: Anyone can create (log events), only admin can read
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // Workflows: Admin only access
    match /workflows/{workflowId} {
      allow read, write: if request.auth != null;
    }
  }
}
