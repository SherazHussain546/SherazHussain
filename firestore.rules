rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-05-V60-STABLE
    
    function isSignedIn() {
      return request.auth != null;
    }

    // projectGoals: Publicly readable, Auth required for all writes
    match /projectGoals/{goalId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // posts: Publicly readable, Auth required for all writes
    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // siteConfig: Publicly readable, Auth required for writes
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // analyticsEvents: Publicly creatable, Auth read access
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read: if isSignedIn();
    }

    // workflows: Admin-only access
    match /workflows/{workflowId} {
      allow read, write: if isSignedIn();
    }
  }
}