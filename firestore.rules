
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-03-V10-FIX
    // REASON: Hardening list permissions for public collections and ensuring robust admin write access.
    
    function isUserAuthenticated() {
      return request.auth != null;
    }

    // projectGoals: Publicly readable (get and list), Auth required for all writes
    match /projectGoals/{goalId} {
      allow get, list: if true;
      allow create, update, delete: if isUserAuthenticated();
    }

    // posts: Publicly readable, Auth required for all writes
    match /posts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if isUserAuthenticated();
    }

    // siteConfig: Publicly readable, Auth required for writes
    match /siteConfig/{configId} {
      allow get, list: if true;
      allow write: if isUserAuthenticated();
    }

    // analyticsEvents: Publicly creatable, Auth (Admin) read access
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow get, list: if isUserAuthenticated();
    }

    // workflows: Admin-only access
    match /workflows/{workflowId} {
      allow read, write: if isUserAuthenticated();
    }
  }
}
