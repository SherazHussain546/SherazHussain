
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-03-V3
    // REASON: Resolving persistent list operation denials on projectGoals by using broad wildcard matching for public read.
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Public collections: Accessible by anyone, manageable by admin
    match /posts/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /projectGoals/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Analytics: Open creation for tracking, admin-only read
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }

    // Admin-only collections
    match /workflows/{workflowId} {
      allow read, write: if isAuthenticated();
    }
  }
}
