/**
 * Portfolio & Article Management Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a dual-access model designed for a professional portfolio website. 
 * Public content (skills, projects, experiences) is globally readable to maximize SEO and 
 * visibility. Administrative control is strictly decoupled from public data using a 
 * "Trusted Admin" pattern, where permissions are granted based on the existence of a 
 * record in a dedicated admin collection.
 *
 * Data Structure:
 * - /user_profile: Singular document containing owner metadata.
 * - /skills, /experiences, /projects, /education: Top-level collections for portfolio content.
 * - /articles: Metadata for long-form content, studies, and courses linked to external Markdown.
 * - /admin_users: A private collection mapping Firebase UIDs to administrative privileges.
 * - /analyticsEvents: High-fidelity event logging for visitor metrics.
 * - /posts: Synchronized social updates and news.
 * - /projectGoals: Strategic technical milestones for the support page.
 * - /siteConfig: Global platform parameters.
 * - /workflows: Private n8n/AI logic definitions.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is registered as an administrator.
     * Uses a direct existence check for high performance and isolation.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid));
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Ensures the document exists before performing updates or deletes.
     */
    function existsAndAdmin() {
      return isAdmin() && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the portfolio owner's profile information.
     */
    match /user_profile/{profileId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    /**
     * @description Rules for portfolio sections.
     */
    match /skills/{skillId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    match /experiences/{experienceId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    match /education/{educationId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    /**
     * @description Rules for Articles (Project studies, courses, .md links).
     */
    match /articles/{articleId} {
      allow get, list: if isAdmin() || resource.data.isPublished == true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    /**
     * @description Rules for Analytics. Allow public create for logging; Admin only for viewing.
     */
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow get, list: if isAdmin();
    }

    /**
     * @description Rules for Social Posts and Updates.
     */
    match /posts/{postId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    /**
     * @description Rules for Project Goals / Milestones.
     */
    match /projectGoals/{goalId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if existsAndAdmin();
    }

    /**
     * @description Rules for Global Site Configuration.
     */
    match /siteConfig/{configId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Workflows. These are private to the admin.
     */
    match /workflows/{workflowId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for identifying users with administrative privileges.
     * @path /admin_users/{userId}
     * @allow User to manage their own admin record (Self-provisioning/Check).
     * @deny Unauthorized users reading or modifying other users' admin status.
     * @principle Authorization Independence via dedicated role collection.
     */
    match /admin_users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Admin status listing is disallowed for privacy.
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }
  }
}