
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-02-V1
    // REASON: Resolving persistent 'list' operation denials by using explicit granular permissions.
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Posts: Publicly readable, admin manageable
    match /posts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Project Goals: Publicly readable, admin manageable
    match /projectGoals/{goalId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Site Config: Publicly readable, admin manageable
    match /siteConfig/{configId} {
      allow get, list: if true;
      allow create, update, delete: if isAuthenticated();
    }

    // Analytics: Anyone can create (log events), only admin can read
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow get, list: if isAuthenticated();
    }

    // Workflows: Admin only access
    match /workflows/{workflowId} {
      allow read, write: if isAuthenticated();
    }
  }
}
