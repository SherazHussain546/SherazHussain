
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-03-V6
    // REASON: Resolving list operation denial by using robust recursive wildcard patterns for collection-wide access.
    
    function isAdmin() {
      return request.auth != null;
    }

    // Public Read Collections (Handled with recursive wildcards for list/get)
    match /projectGoals/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics: Open creation for tracking, Admin read
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Admin-only collections
    match /workflows/{workflowId} {
      allow read, write: if isAdmin();
    }
  }
}
