
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // SECURITY RULES REVISION: 2024-06-05-V20-ULTRA-STABLE
    // This revision uses explicit collection and document matching to ensure 
    // that 'list' operations are correctly authorized for all administrative components.
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // projectGoals: Publicly readable (get/list), Auth required for all writes
    match /projectGoals/{goalId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // posts: Publicly readable (get/list), Auth required for all writes
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // siteConfig: Publicly readable, Auth required for writes
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // analyticsEvents: Publicly creatable, Auth (Admin) read access
    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow read: if isAuthenticated();
    }

    // workflows: Admin-only access
    match /workflows/{workflowId} {
      allow read, write: if isAuthenticated();
    }
  }
}
