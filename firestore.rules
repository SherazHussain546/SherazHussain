
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ["me@sherazhussain546.com", "sheraz@synctech.ie", "admin@synctech.ie"] ||
        request.auth.uid == "wF7mnAaDTqd0sreQTvfc2K5qpZD3" ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
      );
    }

    match /user_profile/{profileId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /skills/{skillId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /experiences/{experienceId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /education/{eduId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /certifications/{certId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /articles/{articleId} {
      allow get, list: if isAdmin() || (resource != null && resource.data.isPublished == true) || (resource == null);
      allow write: if isAdmin();
    }

    match /analyticsEvents/{eventId} {
      allow create: if true;
      allow get, list: if isAdmin();
    }

    match /posts/{postId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /projectGoals/{goalId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow get: if true;
      allow write: if isAdmin();
    }

    match /workflows/{workflowId} {
      allow read, write: if isAdmin();
    }

    match /admin_users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
