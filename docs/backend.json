{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores general information about the portfolio owner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "professionalTitle": { "type": "string" },
        "summary": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "githubProfileUrl": { "type": "string", "format": "uri" },
        "linkedinProfileUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "professionalTitle", "summary", "contactEmail"]
    },
    "Skill": {
      "title": "Skill",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "category", "description"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "type": "object",
      "description": "High-fidelity visitor tracking data.",
      "properties": {
        "type": { "type": "string", "enum": ["page_view"] },
        "path": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "path", "sessionId", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profile/{profileId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Owner metadata."
        }
      },
      {
        "path": "/analyticsEvents/{eventId}",
        "definition": {
          "entityName": "AnalyticsEvent",
          "schema": { "$ref": "#/backend/entities/AnalyticsEvent" },
          "description": "Visitor analytics events."
        }
      }
    ],
    "reasoning": "The firestore structure is built for authorization independence. Admin status is determined by checking for document existence in /admin_users/{uid}, separating public data access from role verification."
  }
}