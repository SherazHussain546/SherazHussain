
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores general information about the portfolio owner.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "professionalTitle": { "type": "string" },
        "summary": { "type": "string" },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "githubProfileUrl": { "type": "string", "format": "uri" },
        "linkedinProfileUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "name", "professionalTitle", "summary", "contactEmail"]
    },
    "Experience": {
      "title": "Experience",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string" },
        "company": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "company", "period", "description"]
    },
    "Certification": {
      "title": "Certification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "issuer": { "type": "string" },
        "date": { "type": "string" },
        "credentialUrl": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "points": { "type": "array", "items": { "type": "string" } },
        "iconName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issuer", "date"]
    },
    "Project": {
      "title": "Project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "fullDescription": { "type": "string" },
        "challenges": { "type": "array", "items": { "type": "string" } },
        "solutions": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          } 
        },
        "results": { "type": "array", "items": { "type": "string" } },
        "stack": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "liveLink": { "type": "string" },
        "image": { "type": "string" },
        "imageHint": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "description", "fullDescription", "stack", "link"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "type": "object",
      "description": "High-fidelity visitor tracking data.",
      "properties": {
        "type": { "type": "string", "enum": ["page_view"] },
        "path": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "path", "sessionId", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profile/{profileId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Owner metadata."
        }
      },
      {
        "path": "/experiences/{experienceId}",
        "definition": {
          "entityName": "Experience",
          "description": "Work history."
        }
      },
      {
        "path": "/certifications/{certId}",
        "definition": {
          "entityName": "Certification",
          "description": "Professional credentials."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "description": "Engineering showcase items."
        }
      },
      {
        "path": "/analyticsEvents/{eventId}",
        "definition": {
          "entityName": "AnalyticsEvent",
          "description": "Visitor analytics events."
        }
      }
    ],
    "reasoning": "Standard dynamic CMS structure for a professional portfolio."
  }
}
